@model SFA.DAS.DigitalCertificates.Web.Models.Certificates.CertificateStandardViewModel
@using SFA.DAS.DigitalCertificates.Web.Controllers
@using SFA.DAS.DigitalCertificates.Web.Enums
@using SFA.DAS.DigitalCertificates.Web.ViewDataKeys
@{
    ViewData[ViewDataKeys.Title] = ViewData[ViewDataKeys.ServiceName] + " Certificate Standard";
    ViewBag.GaData.Vpv = @ViewData[ViewDataKeys.GaDataVpvPrefix] + "certificate-standard";
    var certificateId = Model?.CertificateId;
}

<div class="govuk-width-container">

    @if (Model?.ShowBackLink ?? true)
    {
        <a asp-route="@CertificatesController.CertificatesListRouteGet" class="govuk-back-link">Back</a>
    }

    <main class="govuk-main-wrapper" id="main-content">
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-two-thirds">

                <h1 class="govuk-heading-l">@Model?.CourseName</h1>

                <div class="govuk-panel govuk-panel--confirmation">
                    <div class="govuk-panel__body">
                        <span class="govuk-panel__title">@Model?.OverallGradeBannerDisplay</span>
                    </div>
                </div>

                <h2 class="govuk-heading-m">Your details</h2>
                <dl class="govuk-summary-list">
                    @if (!string.IsNullOrEmpty(Model?.GivenNames))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">First name</dt>
                            <dd class="govuk-summary-list__value">@Model.GivenNames</dd>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model?.FamilyName))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Last name</dt>
                            <dd class="govuk-summary-list__value">@Model.FamilyName</dd>
                        </div>
                    }

                    @if (Model?.Uln != null)
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Unique learner number</dt>
                            <dd class="govuk-summary-list__value">@Model.Uln</dd>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model?.CertificateReference))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Certificate number</dt>
                            <dd class="govuk-summary-list__value">@Model.CertificateReference</dd>
                        </div>
                    }
                </dl>

                <h2 class="govuk-heading-m">Apprenticeship details</h2>
                <dl class="govuk-summary-list">
                    @if (!string.IsNullOrEmpty(Model?.CourseName))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Course</dt>
                            <dd class="govuk-summary-list__value">@Model.CourseName</dd>
                        </div>
                    }

                    @if (Model?.CourseLevel != null)
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Level</dt>
                            <dd class="govuk-summary-list__value">@Model.CourseLevel</dd>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model?.CourseOption))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Option</dt>
                            <dd class="govuk-summary-list__value">@Model.CourseOption</dd>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model?.ProviderName))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Training provider</dt>
                            <dd class="govuk-summary-list__value">@Model.ProviderName</dd>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model?.AssessorName))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Assessment organisation</dt>
                            <dd class="govuk-summary-list__value">@Model.AssessorName</dd>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model?.EmployerName))
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Employer</dt>
                            <dd class="govuk-summary-list__value">@Model.EmployerName</dd>
                        </div>
                    }

                    @if (Model?.StartDate != null)
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Start date</dt>
                            <dd class="govuk-summary-list__value">@Model.StartDate?.ToString("dd MMMM yyyy")</dd>
                        </div>
                    }

                    @if (Model?.DateAwarded != null)
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Date awarded</dt>
                            <dd class="govuk-summary-list__value">@Model.DateAwarded?.ToString("dd MMMM yyyy")</dd>
                        </div>
                    }

                    @if (Model?.OverallGradeEnum.IsAvailable() == true)
                    {
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key">Result</dt>
                            <dd class="govuk-summary-list__value">@Model.OverallGradeResultDisplay</dd>
                        </div>
                    }
                </dl>

                    <form asp-route="@CertificatesController.ContactUsForCertificateCreateRoutePost"
                          asp-route-certificateId="@certificateId"
                          method="post">
                        <p class="govuk-body">
                            If these details are wrong, 
                            <button type="submit" class="das-button--inline-link" data-prevent-double-click="true" data-module="govuk-button">contact us to correct your details</button>.
                        </p>
                    </form>

                <h2 class="govuk-heading-m">Create a sharing link</h2>
                <p class="govuk-body">You can create a secure link to share your apprenticeship certificate. This allows
                    employers, colleges or universities to verify your apprenticeship.</p>
                <a asp-route="@CertificatesController.CreateCertificateSharingRouteGet"
                   asp-route-certificateId="@certificateId" role="button" draggable="false"
                   class="govuk-button govuk-button--secondary" data-module="govuk-button">Create link</a>

                @* TODO: Download your certificate. This is not part of the current ticket and will need to be addressed based on the requirements in upcoming tickets. *@
                <h2 class="govuk-heading-m">Download your certificate</h2>
                <a href="#" role="button" draggable="false" class="govuk-button govuk-button--secondary"
                   data-module="govuk-button">Download certificate (PDF)</a>

                @if (Model?.ShowRequestPrint == true)
                {
                    <h2 class="govuk-heading-m">Request a printed certificate</h2>
                    <p class="govuk-body">
                        We can post a certificate to you. You need to
                        <span class="das-js-show--inline">
                            <a asp-route="@CertificatesController.SelectAddressRouteGet"
                               asp-route-certificateId="@certificateId" title="Request a printed certificate">
                                request a printed certificate
                            </a>
                        </span>
                        <span class="das-js-hide">
                            <a asp-route="@CertificatesController.AddAddressRouteGet"
                               asp-route-certificateId="@certificateId" title="Request a printed certificate">
                                request a printed certificate
                            </a>
                        </span>.
                        Certificates can take up to 3 weeks to arrive.
                    </p>
                }

                @if (Model?.ShowPrintHeader == true)
                {
                    <h2 class="govuk-heading-m">Certificate print status</h2>

                    <dl class="govuk-summary-list">
                        <div class="govuk-summary-list__row">
                            <dt class="govuk-summary-list__key"><span class="govuk-body">Your certificate is</span></dt>
                                    <dd class="govuk-summary-list__value">
                                        <span class="govuk-tag">@Model.PrintStatusDisplay</span>
                                    </dd>
                        </div>
                    </dl>

                    <p class="govuk-body">@Model?.PrintStatusMessage</p>
                    <form asp-route="@CertificatesController.ContactUsForCertificateCreateRoutePost"
                          asp-route-certificateId="@certificateId"
                          method="post">
                        <p class="govuk-body">
                            If your certificate has been lost, 
                            <button type="submit" name="actionType" value="Reprint" class="das-button--inline-link" data-prevent-double-click="true" data-module="govuk-button">contact us for a replacement printed certificate</button>.
                        </p>
                    </form>
                }

            </div>
        </div>
    </main>
</div>